# =============================================================================
# Terraform PowerDNS — exemplo de variáveis
# Copie para terraform.tfvars e ajuste os valores.
# NUNCA commite terraform.tfvars (contém a api_key).
# =============================================================================

pdns_server_url = "http://localhost:8081"
pdns_api_key    = "<valor de PDNS_API_KEY no .env>"

# ---------------------------------------------------------------------------
# Zonas DNS
# ---------------------------------------------------------------------------
zones = {
  "example.com." = {
    kind = "Native"
  }
  "interno.example.com." = {
    kind = "Native"
  }
}

# ---------------------------------------------------------------------------
# Registros DNS
# Tipos suportados: A, AAAA, CNAME, MX, TXT, NS, PTR, SRV, CAA, SSHFP, etc.
# ---------------------------------------------------------------------------
records = [
  # --- example.com ---
  {
    zone    = "example.com."
    name    = "example.com."
    type    = "A"
    ttl     = 300
    records = ["192.168.1.10"]
  },
  {
    zone    = "example.com."
    name    = "www.example.com."
    type    = "CNAME"
    ttl     = 300
    records = ["example.com."]
  },
  {
    zone    = "example.com."
    name    = "mail.example.com."
    type    = "A"
    ttl     = 300
    records = ["192.168.1.20"]
  },
  {
    zone    = "example.com."
    name    = "example.com."
    type    = "MX"
    ttl     = 3600
    records = ["10 mail.example.com."]
  },
  {
    zone    = "example.com."
    name    = "example.com."
    type    = "TXT"
    ttl     = 300
    records = ["\"v=spf1 mx ~all\""]
  },

  # --- interno.example.com ---
  {
    zone    = "interno.example.com."
    name    = "app.interno.example.com."
    type    = "A"
    ttl     = 60
    records = ["10.0.0.100"]
  },
]
