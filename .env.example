# =============================================================================
# PowerDNS Authoritative Server - Exemplo de variáveis de ambiente
# Copie para .env e preencha com valores reais.
# =============================================================================

# --- API (Terraform / HTTP REST) -------------------------------------------
PDNS_API_KEY=<chave-api-segura>

# --- Webserver (API REST) ---------------------------------------------------
PDNS_WEBSERVER_PORT=8081

# --- Porta DNS exposta no host ----------------------------------------------
# Produção: 53 | Dev/teste: porta alta (ex: 5053) para evitar conflito
PDNS_DNS_PORT=5053

# --- Banco de dados (PostgreSQL) --------------------------------------------
PDNS_DB_HOST=db
PDNS_DB_PORT=5432
PDNS_DB_NAME=pdns
PDNS_DB_USER=pdns
PDNS_DB_PASSWORD=<senha-segura>
